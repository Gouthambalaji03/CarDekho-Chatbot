# ── CarDekho Advisor — required environment ──────────────────────────────
# Copy to `.env.local` (Next.js) and fill in. The seed script also reads these.

# Google Gemini API key — used for both the chat agent (gemini-2.0-flash)
# and embeddings (text-embedding-004). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# MongoDB Atlas connection string (no vector index needed — we rank in memory).
# e.g. mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# Optional overrides (sensible defaults applied if omitted)
# MONGODB_DB=cardekho
# GEMINI_CHAT_MODEL=gemini-2.5-flash        # set gemini-2.0-flash if your key has quota for it
# GEMINI_CHAT_FALLBACK_MODEL=gemini-2.5-flash-lite  # used when the primary model returns 503 (overloaded)
# GEMINI_EMBED_MODEL=gemini-embedding-001   # requested at 768 dimensions
